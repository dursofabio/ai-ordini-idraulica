APP_NAME=Laravel
APP_ENV=testing
APP_KEY=base64:p+5zzQNz11AC2PO1t0vF/E/V6P3FLhoW+CfSnQc1bf4=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=testing
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ANTHROPIC_* and EMBEDDING_* (bar BASE_URL) are intentionally omitted here:
# config/services.php gives them sane non-null defaults, and an empty-string
# override (e.g. ANTHROPIC_ENRICHMENT_CACHE_TTL=) breaks `=== null` checks
# such as EnrichmentCache::put().
EMBEDDING_BASE_URL=http://ollama:11434

SEARCH_WEIGHT_VECTOR=0.7
SEARCH_WEIGHT_FTS=0.3
SEARCH_QUERY_CACHE_TTL=3600

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
